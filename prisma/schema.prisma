generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id            String   @id @default(cuid())
  category      String
  team          String
  opponent      String
  matchDate     DateTime
  location      String
  isHome        Boolean
  status        String
  scoreTeam     Int?
  scoreOpponent Int?
  scorers       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  goals         MatchGoal[]
  events        MatchEvent[]
}

model User {
  id                  String                 @id @default(cuid())
  email               String                 @unique
  passwordHash        String
  name                String
  role                String
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  showEmailToMembers  Boolean                @default(false)
  showPhoneToMembers  Boolean                @default(false)
  commissionId        String?
  phone               String?
  signupNote          String?
  memberships         CommissionMembership[]
  passwordResetTokens PasswordResetToken[]
  staffMembers        StaffMember[]
  commission          Commission?            @relation("LegacyUserCommission", fields: [commissionId], references: [id])

  @@index([commissionId])
}

model Commission {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  email       String?
  phone       String?
  isPublished Boolean                @default(true)
  showMembers Boolean                @default(true)
  showEmail   Boolean                @default(false)
  showPhone   Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  memberships CommissionMembership[]
  members     StaffMember[]
  users       User[]                 @relation("LegacyUserCommission")
}

model CommissionMembership {
  id                    String     @id @default(cuid())
  userId                String
  commissionId          String
  isAdmin               Boolean    @default(false)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  isVisibleInCommission Boolean    @default(true)
  roleLabel             String?
  commission            Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commissionId])
  @@index([userId])
  @@index([commissionId])
}

model StaffMember {
  id                String      @id @default(cuid())
  name              String
  roleLabel         String
  sectionTitle      String
  photo             String?
  email             String?
  phone             String?
  isPublished       Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  userId            String?
  commissionId      String?
  isCommissionAdmin Boolean     @default(false)
  commission        Commission? @relation(fields: [commissionId], references: [id])
  user              User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([commissionId])
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model TeamSetting {
  id        String   @id @default(cuid())
  team      String   @unique
  fffUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamGroup {
  id          String   @id @default(cuid())
  title       String
  subtitle    String
  badge       String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  teams       Team[]
}

model Team {
  id          String         @id @default(cuid())
  category    String
  coach       String
  sortOrder   Int            @default(0)
  isPublished Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  groupId     String
  group       TeamGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  schedules   TeamSchedule[]
}

model TeamSchedule {
  id        String   @id @default(cuid())
  day       String
  time      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model NewsItem {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String?
  type          String
  coverImageUrl String?
  fileUrl       String?
  externalUrl   String?
  eventDate     DateTime?
  location      String?
  isPublished   Boolean   @default(false)
  publishedAt   DateTime?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type, isPublished, publishedAt])
  @@index([sortOrder])
}

model RegistrationSettings {
  id             String   @id @default(cuid())
  seasonLabel    String   @default("Saison 2026")
  introTitle     String   @default("S’inscrire au CS Viriat (CSV)")
  introText      String
  periodText     String   @default("juin → septembre")
  contactEmail   String   @default("csviriat-football@orange.fr")
  helloAssoUrl   String?
  cardPaymentUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RegistrationFee {
  id        String   @id @default(cuid())
  category  String
  fee       String
  tombola   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model RegistrationDocument {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String?
  status    String   @default("À venir")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TopScorer {
  id        String   @id @default(cuid())
  name      String
  category  String
  goals     Int      @default(0)
  photoUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model MatchGoal {
  id         String @id @default(cuid())
  matchId    String
  scorerName String
  goals      Int    @default(1)
  category   String

  createdAt DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([category])
}

model MatchEvent {
  id        String   @id @default(cuid())

  matchId   String
  playerId  String
  type      String

  createdAt DateTime @default(now())

  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([playerId])
  @@index([type])
}

model Player {
  id             String       @id @default(cuid())
  firstName      String
  lastName       String

  team           String?
  category       String?

  photoUrl       String?
  photoConsent   Boolean      @default(false)

  isActive       Boolean      @default(true)

  stats          PlayerStat[]
  matchEvents    MatchEvent[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PlayerStat {
  id        String   @id @default(cuid())
  playerId  String
  season    String
  goals     Int      @default(0)
  assists   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, season])
}
