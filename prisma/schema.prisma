generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id            String   @id @default(cuid())
  category      String
  team          String
  opponent      String
  matchDate     DateTime
  location      String
  isHome        Boolean
  status        String
  scoreTeam     Int?
  scoreOpponent Int?
  scorers       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  passwordHash       String
  name               String
  role               String
  isActive           Boolean                @default(true)
  showEmailToMembers Boolean                @default(false)
  showPhoneToMembers Boolean                @default(false)
  phone              String?
  signupNote         String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  // TEMPORAIRE — à garder pendant la transition
  commissionId       String?
  commission         Commission?            @relation("LegacyUserCommission", fields: [commissionId], references: [id], onDelete: SetNull)

  // TEMPORAIRE — à garder pour ne pas casser l'existant tout de suite
  staffMembers       StaffMember[]

  // NOUVELLE RELATION PROPRE
  memberships        CommissionMembership[]

  @@index([commissionId])
}

model Commission {
  id          String                 @id @default(cuid())
  name        String
  slug        String                 @unique
  description String?
  email       String?
  phone       String?
  isPublished Boolean                @default(true)
  showMembers Boolean                @default(true)
  showEmail   Boolean                @default(false)
  showPhone   Boolean                @default(false)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  // TEMPORAIRE — ancien système
  users       User[]                 @relation("LegacyUserCommission")

  // Affichage site / organigramme
  members     StaffMember[]

  // NOUVELLE RELATION PROPRE
  memberships CommissionMembership[]
}

model CommissionMembership {
  id                    String      @id @default(cuid())
  userId                String
  commissionId          String
  isAdmin               Boolean     @default(false)
  roleLabel             String?
  isVisibleInCommission Boolean     @default(true)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  commission            Commission  @relation(fields: [commissionId], references: [id], onDelete: Cascade)

  @@unique([userId, commissionId])
  @@index([userId])
  @@index([commissionId])
}

model StaffMember {
  id                String      @id @default(cuid())
  name              String
  roleLabel         String
  sectionTitle      String
  photo             String?
  email             String?
  phone             String?
  isPublished       Boolean     @default(true)

  // TEMPORAIRE — à supprimer plus tard quand tout passera par CommissionMembership
  isCommissionAdmin Boolean     @default(false)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // TEMPORAIRE — à garder si tu veux encore relier un membre staff à un user plus tard
  userId            String?
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Sert à l’AFFICHAGE des membres dans une commission
  commissionId      String?
  commission        Commission? @relation(fields: [commissionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([commissionId])
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  websiteUrl  String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamGroup {
  id          String   @id @default(cuid())
  title       String
  subtitle    String
  badge       String
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       Team[]
}

model Team {
  id          String         @id @default(cuid())
  category    String
  coach       String
  sortOrder   Int            @default(0)
  isPublished Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  groupId     String
  group       TeamGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  schedules   TeamSchedule[]
}

model TeamSchedule {
  id          String   @id @default(cuid())
  day         String
  time        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model NewsItem {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String?
  type          String
  coverImageUrl String?
  fileUrl       String?
  externalUrl   String?
  eventDate     DateTime?
  location      String?
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([type, isPublished, publishedAt])
  @@index([sortOrder])
}
model RegistrationSettings {
  id                 String   @id @default(cuid())
  seasonLabel        String   @default("Saison 2026")
  introTitle         String   @default("S’inscrire au CS Viriat (CSV)")
  introText          String
  periodText         String   @default("juin → septembre")
  contactEmail       String   @default("csviriat-football@orange.fr")
  helloAssoUrl       String?
  cardPaymentUrl     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RegistrationFee {
  id        String   @id @default(cuid())
  category  String
  fee       String
  tombola   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model RegistrationDocument {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String?
  status    String   @default("À venir")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}
